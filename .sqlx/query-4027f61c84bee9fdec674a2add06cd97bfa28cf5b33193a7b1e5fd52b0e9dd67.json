  "query": "\n            SELECT event_id, room_id, sender, type AS event_type, state_key,\n                   content, auth_events, prev_events, hashes, signatures,\n                   unsigned, origin_server_ts, depth\n            FROM events\n            WHERE stream_position > $1\n            ORDER BY stream_position ASC\n            LIMIT $2\n            ",
