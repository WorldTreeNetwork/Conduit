{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT id, destination, kind, txn_id, payload, attempts\n            FROM fed_outbound_queue\n            WHERE status = 'pending'\n              AND destination = $1\n              AND next_attempt_at <= now()\n            ORDER BY next_attempt_at, id\n            LIMIT $2\n            ",
